---
import contactLinks from '../data/contactLinks.json';

interface Props {
  title: string;
  description?: string;
  pathname?: string;
  image?: string;
  locale?: string;
}

const {
  title,
  description = 'Bienvenido al Candido Stack. Explora mis proyectos de desarrollo web, habilidades técnicas y mi trayectoria como desarrollador Full Stack.',
  pathname = '/',
  image = '/images/avatar.webp',
  locale = 'es_ES'
} = Astro.props;

const siteUrl = 'https://candido-stack.vercel.app';
const normalizedPathname = pathname.startsWith('/') ? pathname : `/${pathname}`;
const canonical = `${siteUrl}${normalizedPathname}`;
const pageDescription = description;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Cándido Aguilar',
  url: siteUrl,
  sameAs: [
    contactLinks.contact.github,
    contactLinks.contact.linkedin
  ],
  jobTitle: 'Full-stack Developer',
  description: pageDescription
};
---
<title>{title}</title>
<meta name="description" content={pageDescription} />
<link rel="canonical" href={canonical} />
<meta name="theme-color" content="#0f172a" />
<meta property="og:type" content="website" />
<meta property="og:locale" content={locale} />
<meta property="og:title" content={title} />
<meta property="og:description" content={pageDescription} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={`${siteUrl}${image}`} />
<meta property="og:site_name" content="Cándido Stack" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={pageDescription} />
<meta name="twitter:image" content={`${siteUrl}${image}`} />
<script type="application/ld+json">
{JSON.stringify(jsonLd)}
</script>
